{
    "name": "opensoundboard",
    "productName": "OpenSoundBoard",
    "version": "1.0.0",
    "description": "A modern, dark-themed soundboard application with dual audio output, global shortcuts, and remote control.",
    "author": "Florian Göhring",
    "main": "dist/main/main.js",
    "scripts": {
        "start": "npm run build && electron .",
        "dev": "vite",
        "clean": "rimraf dist release",
        "build": "npm run build:main && npm run build:preload && npm run build:renderer",
        "build:main": "vite build -c vite.main.config.ts",
        "build:preload": "vite build -c vite.preload.config.ts",
        "build:renderer": "vite build -c vite.renderer.config.ts",
        "dist": "npm run build && electron-builder",
        "dist:mac": "npm run build && electron-builder --mac",
        "dist:win": "npm run build && electron-builder --win",
        "dist:linux": "npm run build && electron-builder --linux",
        "postinstall": "electron-builder install-app-deps"
    },
    "dependencies": {
        "electron-squirrel-startup": "^1.0.1",
        "express": "^4.21.2",
        "howler": "^2.2.4",
        "jimp": "^1.6.0",
        "qrcode": "^1.5.4",
        "uiohook-napi": "^1.5.4",
        "uuid": "^13.0.0",
        "wavesurfer.js": "^7.12.1",
        "ws": "^8.18.1",
        "zustand": "^5.0.3"
    },
    "devDependencies": {
        "@types/express": "^5.0.0",
        "@types/howler": "^2.2.12",
        "@types/node": "^22.13.4",
        "@types/qrcode": "^1.5.5",
        "@types/react": "^19.0.10",
        "@types/react-dom": "^19.0.4",
        "@types/uuid": "^10.0.0",
        "@types/ws": "^8.18.0",
        "@vitejs/plugin-react": "^4.3.4",
        "autoprefixer": "^10.4.20",
        "electron": "^35.1.2",
        "electron-builder": "^26.0.0",
        "png2icons": "^2.0.1",
        "postcss": "^8.5.1",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "rimraf": "^6.0.1",
        "tailwindcss": "^3.4.17",
        "tar": "^7.5.7",
        "typescript": "^5.7.3",
        "vite": "^6.0.7"
    },
    "overrides": {
        "tar": "^7.5.7",
        "tmp": "^0.2.5",
        "make-fetch-happen": "^14.0.0"
    }
}